  <worksheets>
    <worksheet name='Avg EV by State'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#e6ecf0' fontname='Tableau Semibold' fontsize='14'>Avg Electric Vehicle Produced in a State</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (EVP workbook)' name='federated.1rrey2s1qh88ph16l70ja0cns3t3' />
          </datasources>
          <datasource-dependencies datasource='federated.1rrey2s1qh88ph16l70ja0cns3t3'>
            <column caption='EV produced by State' datatype='real' name='[Calculation_1070167919008727042]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(Model)/COUNTD([State])' />
            </column>
            <column caption='Reset Filter' datatype='string' name='[Calculation_1070167919011086340]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&apos;&apos;' />
              <aliases>
                <alias key='&quot;&quot;' value='Reset Filter' />
              </aliases>
            </column>
            <column caption='Reset Filter 2' datatype='string' name='[Calculation_1070167919031689221]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&apos;&apos;' />
            </column>
            <column datatype='string' name='[Clean Alternative Fuel Vehicle (CAFV) Eligibility]' role='dimension' type='nominal' />
            <column datatype='string' name='[Electric Vehicle Type]' role='dimension' type='nominal' />
            <column datatype='string' name='[Make]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Model Year]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Model]' role='dimension' type='nominal' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Clean Alternative Fuel Vehicle (CAFV) Eligibility]' derivation='None' name='[none:Clean Alternative Fuel Vehicle (CAFV) Eligibility:nk]' pivot='key' type='nominal' />
            <column-instance column='[Electric Vehicle Type]' derivation='None' name='[none:Electric Vehicle Type:nk]' pivot='key' type='nominal' />
            <column-instance column='[Make]' derivation='None' name='[none:Make:nk]' pivot='key' type='nominal' />
            <column-instance column='[Model Year]' derivation='None' name='[none:Model Year:ok]' pivot='key' type='ordinal' />
            <column-instance column='[State]' derivation='None' name='[none:State:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1070167919008727042]' derivation='User' name='[usr:Calculation_1070167919008727042:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1rrey2s1qh88ph16l70ja0cns3t3].[Action (Clean Alternative Fuel Vehicle (CAFV) Eligibility,Make)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action22_D4582BB2E84A4184BDFB554089E33436]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[Clean Alternative Fuel Vehicle (CAFV) Eligibility]' />
              <groupfilter function='level-members' level='[Make]' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.1rrey2s1qh88ph16l70ja0cns3t3].[Action (Electric Vehicle Type)]'>
